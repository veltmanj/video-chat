apiVersion: v1
kind: Service
metadata:
  name: loki
  namespace: ${K8S_NAMESPACE}
  labels:
    app.kubernetes.io/name: loki
spec:
  ports:
    - name: http
      port: 3100
      targetPort: 3100
  selector:
    app.kubernetes.io/name: loki
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: loki-data
  namespace: ${K8S_NAMESPACE}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: ${K8S_LOKI_STORAGE_CLASS}
  resources:
    requests:
      storage: ${K8S_LOKI_STORAGE_SIZE}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: loki
  namespace: ${K8S_NAMESPACE}
spec:
  strategy:
    type: Recreate
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: loki
  template:
    metadata:
      labels:
        app.kubernetes.io/name: loki
        app: loki
    spec:
      securityContext:
        fsGroup: 10001
        fsGroupChangePolicy: OnRootMismatch
      containers:
        - name: loki
          image: grafana/loki:3.6.0
          imagePullPolicy: IfNotPresent
          securityContext:
            runAsUser: 10001
            runAsGroup: 10001
          args:
            - -config.file=/etc/loki/loki-config.yml
          ports:
            - containerPort: 3100
              name: http
          volumeMounts:
            - name: config
              mountPath: /etc/loki
              readOnly: true
            - name: data
              mountPath: /loki
      volumes:
        - name: config
          configMap:
            name: loki-config
        - name: data
          persistentVolumeClaim:
            claimName: loki-data
