apiVersion: v1
kind: Service
metadata:
  name: blackbox
  namespace: ${K8S_NAMESPACE}
  labels:
    app.kubernetes.io/name: blackbox
spec:
  ports:
    - name: http
      port: 9115
      targetPort: 9115
  selector:
    app.kubernetes.io/name: blackbox
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: blackbox
  namespace: ${K8S_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: blackbox
  template:
    metadata:
      labels:
        app.kubernetes.io/name: blackbox
        app: blackbox
    spec:
      containers:
        - name: blackbox
          image: prom/blackbox-exporter:v0.25.0
          imagePullPolicy: IfNotPresent
          args:
            - --config.file=/etc/blackbox_exporter/blackbox.yml
          ports:
            - containerPort: 9115
              name: http
          volumeMounts:
            - name: config
              mountPath: /etc/blackbox_exporter
              readOnly: true
      volumes:
        - name: config
          configMap:
            name: blackbox-config

