apiVersion: v1
kind: Service
metadata:
  name: broker
  namespace: ${K8S_NAMESPACE}
  labels:
    app.kubernetes.io/name: broker
spec:
  ports:
    - name: http
      port: 9898
      targetPort: 9898
  selector:
    app.kubernetes.io/name: broker
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: broker
  namespace: ${K8S_NAMESPACE}
spec:
  replicas: ${K8S_BROKER_REPLICAS}
  selector:
    matchLabels:
      app.kubernetes.io/name: broker
  template:
    metadata:
      labels:
        app.kubernetes.io/name: broker
        app: broker
    spec:
      containers:
        - name: broker
          image: ${BROKER_IMAGE}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 9898
              name: http
          envFrom:
            - configMapRef:
                name: app-config
          env:
            - name: BROKER_BACKOFFICE_ENDPOINT
              value: ws://backoffice:7901/rsocket
            - name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE
              value: health,info,prometheus
            - name: SPRING_APPLICATION_JSON
              value: >-
                {
                  "broker": {
                    "jwt": {
                      "providers": [
                        {
                          "enabled": ${BROKER_JWT_GOOGLE_ENABLED},
                          "name": "google",
                          "issuers": ["https://accounts.google.com", "accounts.google.com"],
                          "audiences": ["${BROKER_JWT_GOOGLE_AUDIENCE}"],
                          "jwkSetUri": "${BROKER_JWT_GOOGLE_JWK_SET_URI}"
                        },
                        {
                          "enabled": ${BROKER_JWT_APPLE_ENABLED},
                          "name": "apple",
                          "issuers": ["https://appleid.apple.com"],
                          "jwkSetUri": "${BROKER_JWT_APPLE_JWK_SET_URI}"
                        },
                        {
                          "enabled": ${BROKER_JWT_X_ENABLED},
                          "name": "x",
                          "jwkSetUri": "${BROKER_JWT_X_JWK_SET_URI}"
                        }
                      ]
                    }
                  }
                }
          readinessProbe:
            httpGet:
              path: /actuator/health
              port: 9898
            initialDelaySeconds: 20
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /actuator/health
              port: 9898
            initialDelaySeconds: 40
            periodSeconds: 20

