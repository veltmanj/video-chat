apiVersion: v1
kind: Service
metadata:
  name: backoffice
  namespace: ${K8S_NAMESPACE}
  labels:
    app.kubernetes.io/name: backoffice
spec:
  ports:
    - name: http
      port: 7901
      targetPort: 7901
  selector:
    app.kubernetes.io/name: backoffice
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: backoffice
  namespace: ${K8S_NAMESPACE}
spec:
  replicas: ${K8S_BACKOFFICE_REPLICAS}
  selector:
    matchLabels:
      app.kubernetes.io/name: backoffice
  template:
    metadata:
      labels:
        app.kubernetes.io/name: backoffice
        app: backoffice
    spec:
      containers:
        - name: backoffice
          image: ${BACKOFFICE_IMAGE}
          imagePullPolicy: Always
          ports:
            - containerPort: 7901
              name: http
          envFrom:
            - configMapRef:
                name: app-config
          env:
            - name: SPRING_DATASOURCE_URL
              value: "jdbc:postgresql://social-db:5432/${SOCIAL_DB_NAME}"
            - name: SPRING_DATASOURCE_USERNAME
              value: "${SOCIAL_DB_USER}"
            - name: SPRING_DATASOURCE_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: app-secrets
                  key: SOCIAL_DB_PASSWORD
            - name: MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE
              value: health,info,prometheus
            - name: BACKOFFICE_SOCIAL_MEDIA_ENDPOINT
              value: http://minio:9000
            - name: BACKOFFICE_SOCIAL_MEDIA_ACCESS_KEY
              value: "${MINIO_ROOT_USER}"
            - name: BACKOFFICE_SOCIAL_MEDIA_SECRET_KEY
              valueFrom:
                secretKeyRef:
                  name: app-secrets
                  key: MINIO_ROOT_PASSWORD
            - name: BACKOFFICE_AI_API_KEY
              valueFrom:
                secretKeyRef:
                  name: app-secrets
                  key: BACKOFFICE_AI_API_KEY
          readinessProbe:
            httpGet:
              path: /actuator/health
              port: 7901
            initialDelaySeconds: 20
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /actuator/health
              port: 7901
            initialDelaySeconds: 40
            periodSeconds: 20
