K8S_NAMESPACE=videochat
K8S_HOST=videochat.local
K8S_INGRESS_CLASS_NAME=nginx
K8S_TLS_SECRET_NAME=videochat-tls

K8S_IMAGE_REGISTRY=
K8S_IMAGE_TAG=latest
K8S_PUSH_IMAGES=false

K8S_SOCIAL_DB_STORAGE_CLASS=standard
K8S_SOCIAL_DB_STORAGE_SIZE=10Gi
K8S_MINIO_STORAGE_CLASS=standard
K8S_MINIO_STORAGE_SIZE=20Gi
K8S_PROMETHEUS_STORAGE_CLASS=standard
K8S_PROMETHEUS_STORAGE_SIZE=10Gi
K8S_LOKI_STORAGE_CLASS=standard
K8S_LOKI_STORAGE_SIZE=10Gi
K8S_GRAFANA_STORAGE_CLASS=standard
K8S_GRAFANA_STORAGE_SIZE=5Gi

K8S_FRONTEND_REPLICAS=1
K8S_BROKER_REPLICAS=1
K8S_BACKOFFICE_REPLICAS=1

GOOGLE_OAUTH_CLIENT_ID=
VIDEOCHAT_APP_MODE=production
VIDEOCHAT_AI_AGENT_ENABLED=false
VIDEOCHAT_AI_AGENT_ENDPOINT=/social-api/social/v1/rooms/{roomId}/assistant-replies
VIDEOCHAT_AI_AGENT_NAME=Pulse Copilot
VIDEOCHAT_AI_AGENT_MENTION=@pulse

BROKER_JWT_ENABLED=true
BROKER_JWT_CACHE_TTL=15m
BROKER_JWT_CLOCK_SKEW=30s
BROKER_JWT_GOOGLE_ENABLED=true
BROKER_JWT_GOOGLE_AUDIENCE=
BROKER_JWT_GOOGLE_JWK_SET_URI=https://www.googleapis.com/oauth2/v3/certs
BROKER_JWT_APPLE_ENABLED=false
BROKER_JWT_APPLE_JWK_SET_URI=https://appleid.apple.com/auth/keys
BROKER_JWT_X_ENABLED=false
BROKER_JWT_X_JWK_SET_URI=

SOCIAL_DB_NAME=videochat
SOCIAL_DB_USER=videochat
SOCIAL_DB_PASSWORD=

MINIO_ROOT_USER=videochat-minio
MINIO_ROOT_PASSWORD=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

BACKOFFICE_AI_ENABLED=false
BACKOFFICE_AI_API_KEY=
BACKOFFICE_AI_MODEL=gpt-5-mini
BACKOFFICE_AI_ASSISTANT_NAME=Pulse Copilot
BACKOFFICE_SOCIAL_GOOGLE_AUDIENCE=
BACKOFFICE_SOCIAL_GOOGLE_JWK_SET_URI=https://www.googleapis.com/oauth2/v3/certs
BACKOFFICE_SOCIAL_MEDIA_ENABLED=true
BACKOFFICE_SOCIAL_MEDIA_BUCKET=social-media
BACKOFFICE_SOCIAL_MEDIA_MAX_UPLOAD_BYTES=26214400
BACKOFFICE_SOCIAL_MEDIA_MAX_FILES_PER_POST=4
