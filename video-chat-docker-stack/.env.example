VIDEOCHAT_HOST=localhost
GOOGLE_OAUTH_CLIENT_ID=
VIDEOCHAT_APP_MODE=production
CADDY_IMAGE=caddy:2.10.2
FRONTEND_CONTAINER_NAME=videochat-frontend
BROKER_CONTAINER_NAME=videochat-broker
BACKOFFICE_CONTAINER_NAME=videochat-backoffice
CADDY_CONTAINER_NAME=videochat-caddy
VAULT_IMAGE=hashicorp/vault:1.17
VAULT_CONTAINER_NAME=videochat-vault
VAULT_INIT_CONTAINER_NAME=videochat-vault-init
CADDY_LOCAL_CA_FILENAME=caddy-local-root-ca.crt
VAULT_HOST_PORT=8200
VAULT_DEV_ROOT_TOKEN_ID=change-me-local-dev-vault-token
VAULT_KV_MOUNT=secret
VAULT_PROVIDER_FIELD=jwks_json
VAULT_SOCIAL_DB_SECRET_PATH=runtime/social-db
VAULT_MINIO_SECRET_PATH=runtime/minio
VAULT_GRAFANA_SECRET_PATH=runtime/grafana
VAULT_BROKER_POLICY_NAME=broker-jwt-read
VAULT_BOOTSTRAP_SOCIAL_DB_PASSWORD=
VAULT_BOOTSTRAP_MINIO_ROOT_PASSWORD=
VAULT_BOOTSTRAP_GRAFANA_ADMIN_PASSWORD=
BROKER_JWT_ENABLED=true
BROKER_JWT_CACHE_TTL=15m
BROKER_JWT_CLOCK_SKEW=30s
SOCIAL_DB_IMAGE=postgres:16-alpine
SOCIAL_DB_CONTAINER_NAME=videochat-social-db
SOCIAL_DB_NAME=videochat
SOCIAL_DB_USER=videochat
SOCIAL_DB_VOLUME_NAME=social-db-data
MINIO_IMAGE=minio/minio:latest
MINIO_CONTAINER_NAME=videochat-minio
MINIO_ROOT_USER=videochat-minio
MINIO_VOLUME_NAME=minio-data
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
PROMETHEUS_CONTAINER_NAME=videochat-prometheus
PROMETHEUS_HOST_PORT=9090
BLACKBOX_EXPORTER_IMAGE=prom/blackbox-exporter:v0.25.0
BLACKBOX_EXPORTER_CONTAINER_NAME=videochat-blackbox
LOKI_IMAGE=grafana/loki:3.6.0
LOKI_CONTAINER_NAME=videochat-loki
PROMTAIL_IMAGE=grafana/promtail:3.6.0
PROMTAIL_CONTAINER_NAME=videochat-promtail
GRAFANA_IMAGE=grafana/grafana:11.1.0
GRAFANA_CONTAINER_NAME=videochat-grafana
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
BACKOFFICE_SOCIAL_MEDIA_ENABLED=true
BACKOFFICE_SOCIAL_MEDIA_BUCKET=social-media
BACKOFFICE_SOCIAL_MEDIA_MAX_UPLOAD_BYTES=26214400
BACKOFFICE_SOCIAL_MEDIA_MAX_FILES_PER_POST=4
SOCIAL_DB_SEED_CONTAINER_NAME=videochat-social-db-seed
SOCIAL_DB_SEED_ENABLED=false
SOCIAL_DB_SEED_FORCE=false
SOCIAL_DB_DEV_NAME=videochat_dev
SOCIAL_DB_DEV_CONTAINER_NAME=videochat-social-db-dev
SOCIAL_DB_DEV_VOLUME_NAME=social-db-dev-data
SOCIAL_DB_DEV_SEED_CONTAINER_NAME=videochat-social-db-seed-dev
BROKER_JWT_GOOGLE_ENABLED=true
BACKOFFICE_SOCIAL_GOOGLE_AUDIENCE=
BROKER_JWT_GOOGLE_AUDIENCE=
BROKER_JWT_APPLE_ENABLED=false
BROKER_JWT_X_ENABLED=false
BACKOFFICE_API_EXPOSED=false
BACKOFFICE_RSOCKET_EXPOSED=false
VAULT_GOOGLE_SECRET_PATH=jwt/providers/google
VAULT_GOOGLE_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
VAULT_APPLE_SECRET_PATH=jwt/providers/apple
VAULT_APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
VAULT_X_SECRET_PATH=jwt/providers/x
VAULT_X_JWKS_URL=
